# =============================================================================
# Mall för .env.local — kopiera till filen ".env.local" i projektroten
# =============================================================================

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role — endast server (sparar projekt, kringgår RLS). Lägg aldrig i klientkod.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Supabase Auth (Dashboard → Authentication → URL Configuration) ---
# Lägg till omdirigerings-URL:er, t.ex.:
#   http://localhost:3000/auth/callback
#   https://din-domän.se/auth/callback
# Under "Sign up" kan du stänga av "Confirm email" under utveckling om du vill slippa bekräftelsemail.

# SQL som ska körts i SQL Editor:
#   supabase/sql/001_portfolio_projects.sql
#   supabase/sql/002_profiles.sql
#   supabase/sql/003_portfolio_project_rows.sql   (valfritt — en DB-rad per projekt utöver JSON-listan)
#   supabase/sql/004_portfolio_about.sql          (Om mig — rubrik + stycken)
#   supabase/sql/005_portfolio_experience.sql     (Tidslinje — milstolpar)
#   supabase/sql/006_portfolio_gaming.sql         (Gaming — layout + spel)
#   supabase/sql/007_portfolio_setup.sql          (Setup — dator + perifer)
#   supabase/sql/008_portfolio_social.sql         (Socialt — kanaler + rubriker)
#   supabase/sql/009_portfolio_skills.sql         (Skills — kategorier + verktyg)
#
# Dela dev över internet: `npm run dev:share` (kräver ngrok installerat + authtoken). Sätt OPEN_BROWSER=0 för att inte öppna webbläsaren automatiskt.

# (Äldre admin med ADMIN_PASSWORD / ADMIN_JWT_SECRET används inte längre.)

# --- Steam-speltid (valfritt — gaming-kort + /gaming/[slug]) ---
# Skapa nyckel: https://steamcommunity.com/dev/apikey
# STEAM_WEB_API_KEY=din_web_api_nyckel
# Profil → 64-bit Steam ID (t.ex. från https://steamid.io )
# STEAM_ID=76561198xxxxxxxx
# Kräver att spelbiblioteket är publikt under Steam → Profil → Integritet.
# Fyller /gaming med upp till 12 spel (mest speltid) som inte redan är main/topp 3 i gaming-games.ts.
